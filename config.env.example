# Скопируйте в config.env и заполните значения
# Паттерн из 3dtoday — основной файл конфигурации для LLM и поиска

# LLM Provider: openai | ollama
LLM_PROVIDER=openai

# OpenAI / ProxyAPI
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT=120

# Ollama (локально)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# Graph
GRAPH_BACKEND=networkx

# Qdrant + embeddings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=scinikel_docs
HF_MODEL_NAME=intfloat/multilingual-e5-base
EMBEDDING_DIMENSION=768

# Rerank (паттерн 3dtoday/RetrievalAgent)
RERANK_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# Multimodal CLIP (этап 6a — см. 3dtoday/openclip_embeddings.py)
# OPENCLIP_MODEL=ViT-B-16
# OPENCLIP_PRETRAINED=openai
# IMAGE_EMBEDDING_DIMENSION=512
# QDRANT_IMAGE_COLLECTION=scinikel_images

# Vision LLM (этап 6b — см. 3dtoday/vision_analyzer.py)
# GEMINI_API_KEY=your_key_here
# GEMINI_BASE_URL=https://api.proxyapi.ru/google
# GEMINI_MODEL=gemini-3.5-flash
# OLLAMA_VISION_MODEL=llava
# OLLAMA_VISION_TIMEOUT=300
# VISION_ENABLED=true
# CLIP_ENABLED=true

DEBUG=true
